[user]
  name = Pablo Hernandez
  email = phernandezm07@gmail.com

[core]
  compression = 9
  whitespace = error
  preloadindex = true

[init]
  defaultBranch = dev

[diff]
  context = 3
  renames = copies
  interHunkContext = 10

[pager]
  diff = diff-so-fancy | $PAGER

[diff-so-fancy]
  markEmptyLines = false

[color "diff"]
  meta = brightblack bold
  frag = magenta
  context = white
  whitespace = yellow reverse
  old = red

[interactive]
  diffFilter = diff-so-fancy --patch

[url "git@github.com:pablohernandezm/"]
  insteadOf = "me:"

[url "git@github.com:"]
  insteadOf = "gh:"
